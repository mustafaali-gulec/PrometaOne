root = true

# Genel — tüm dosyalar
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript / JavaScript / JSON / YAML / MD
[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,md,mdx,css,scss,html}]
indent_style = space
indent_size = 2

# Python (ml-service) — PEP 8
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# Makefile zorunlu olarak tab kullanır
[Makefile]
indent_style = tab

# Windows batch ve PowerShell — CRLF gerekli
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Markdown'da satır sonu boşluğu tutulur (iki boşluk = line break)
[*.md]
trim_trailing_whitespace = false
