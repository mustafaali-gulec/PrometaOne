# Construction Service — ortam değişkenleri
NODE_ENV=development
PORT=3002
HOST=0.0.0.0

# Servisin KENDİ veritabanı (DB-per-service)
DATABASE_URL=postgres://prometa:prometa123@localhost:5432/prometa_construction

# Monolit (auth) ile AYNI olmalı — token'lar paylaşılan secret ile doğrulanır
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars-please

CORS_ORIGINS=http://localhost:5173

# Kafka (opsiyonel) — boşsa event publisher no-op çalışır
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=construction-service
KAFKA_TOPIC_PREFIX=construction
