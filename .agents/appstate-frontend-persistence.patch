+    // 2) Backend (token varsa)
+    const token = getAccessToken();
+    if (!token) return localOk;
+    try {
+      const res = await fetch("/v1/app-state/" + encodeURIComponent(BACKEND_DATA_KEY), {
+        method: "PUT",
+        headers: { Authorization: `Bearer ${token}`, "Content-Type": "application/json" },
+        body: JSON.stringify({ value: blob }),
+      });
+      if (res.ok) return true;        // backend kalıcı yazdı → başarı (localStorage kotası önemsiz)
+      return localOk;                  // backend hatası → yerel sonuca düş
+    } catch {
