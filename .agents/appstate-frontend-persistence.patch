   /* ---- Persist data ---- */
+  // Veri blob'u backend'e (PostgreSQL JSONB, /v1/app-state) yazılır; localStorage
+  // yalnızca çevrimdışı önbellek (best-effort). Böylece ~5MB localStorage kotası
+  // dolsa bile kayıt backend'e gider (kota-bağımsız) ve tarayıcılar arası paylaşılır.
+  const BACKEND_DATA_KEY = "promet:data";
+  const getAccessToken = () => {
+    try { return typeof localStorage !== "undefined" ? localStorage.getItem("promet_access_token") : null; }
+    catch { return null; }
+  };
+  const persistData = async (blob) => {
+    // 1) Yerel önbellek (kota dolsa bile sorun değil — backend asıl kaynak)
+    let localOk = false;
