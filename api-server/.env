# =====================================================================
# PROMETA ONE — API Server Environment Variables
# =====================================================================
# .env.example dosyasını .env olarak kopyalayıp doldurun:
#   cp .env.example .env

# === Application ===
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://prometa:password@localhost:5432/prometa_one
# Alternatif olarak parça parça:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=prometa
# PG_PASSWORD=password
# PG_DATABASE=prometa_one

# === Authentication ===
JWT_SECRET=Burayauzunrastgelemetinmustafaaligulec
JWT_REFRESH_SECRET=Burayauzunrastgelemetinmustafaaligulec6651
ACCESS_TOKEN_TTL=3600          # 1 saat
REFRESH_TOKEN_TTL=2592000      # 30 gün

# === Email Configuration ===
# Üç provider seçeneği var:
#  1. "console" — Email'i console'a yazar (development)
#  2. "smtp"    — Standart SMTP (Gmail, Outlook, custom)
#  3. "sendgrid" — SendGrid API (önerilen production)

EMAIL_PROVIDER=gulec15@gmail.com	
# EMAIL_PROVIDER=smtp
# EMAIL_PROVIDER=sendgrid

# === SMTP Settings (EMAIL_PROVIDER=smtp ise gerekli) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false              # true if port 465
SMTP_USER=noreply@prometahr.com
SMTP_PASS=
SMTP_FROM="Prometa One <noreply@prometahr.com>"

# Gmail için uygulama parolası gerekir:
# https://myaccount.google.com/apppasswords

# === SendGrid (EMAIL_PROVIDER=sendgrid ise gerekli) ===
# SENDGRID_API_KEY=SG.xxx
# EMAIL_FROM=noreply@prometahr.com

# === TCMB EVDS API (kur entegrasyonu) ===
# TCMB_API_KEY=your-evds-api-key

# === Logo eLogo (e-Fatura) ===
# ELOGO_USERNAME=
# ELOGO_PASSWORD=
# ELOGO_URL=https://www.elogoportal.com.tr/efaturaPortalServices

# === AI (Anthropic) ===
# Frontend doğrudan claude.ai/api üzerinden çağırır
# ANTHROPIC_API_KEY backend tarafında değil, sadece artifact wrapper'da

# === Rate Limiting (opsiyonel) ===
RATE_LIMIT_WINDOW=900000       # 15 dk (ms)
RATE_LIMIT_MAX=100             # IP başına maks istek

# CORS — frontend'in adresi:
CORS_ORIGINS=http://localhost:5173

